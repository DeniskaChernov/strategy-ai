{
  "name": "strategy-ai",
  "version": "1.1.0",
  "description": "Strategy AI — full-stack SaaS for strategic planning",
  "main": "server/index.js",
  "scripts": {
    "build": "mkdir -p public && esbuild strategy-ai-full.tsx --bundle --outfile=public/app.js --jsx=transform --define:process.env.NODE_ENV='\"production\"' --minify",
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "seed": "node server/seed.js",
    "prepare": "husky",
    "deploy": "git add -A && git status --short && (git diff --cached --quiet || (git commit -m \"chore: auto-deploy\" && git push))"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "esbuild": "^0.20.2",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "stripe": "^15.5.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
