{
  "name": "strategy-ai",
  "version": "1.1.0",
  "description": "Strategy AI — full-stack SaaS for strategic planning",
  "main": "server/index.js",
  "scripts": {
    "build": "node build.js",
    "ci": "node build.js && node scripts/verify-build-artifacts.js",
    "start": "node server/index.js",
    "dev": "node scripts/sync-css.js && nodemon server/index.js",
    "seed": "node server/seed.js",
    "prepare": "node -e \"if (process.env.CI === 'true' || process.env.HUSKY === '0') process.exit(0); require('child_process').execSync('npx husky', {stdio:'inherit'})\"",
    "deploy": "git add -A && git status --short && (git diff --cached --quiet || (git commit -m \"chore: auto-deploy\" && git push))"
  },
  "dependencies": {
    "@sentry/node": "^8.55.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "esbuild": "^0.20.2",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.7.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.5",
    "pptxgenjs": "^4.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "stripe": "^15.5.0",
    "three": "^0.183.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
