# ── Database (Railway PostgreSQL — копируй из Railway > Variables) ─────────────
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── JWT ───────────────────────────────────────────────────────────────────────
# Сгенерируй: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_64_BYTE_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_RANDOM_64_BYTE_HEX_STRING

# Триальный период (дней)
TRIAL_DAYS=7

# ── Мониторинг ──────────────────────────────────────────
SENTRY_DSN=               # https://sentry.io → создайте проект Node.js

# ── Email (Resend — бесплатно 3000 писем/мес) ─────────────────────────────────
# Получи API ключ на https://resend.com
RESEND_API_KEY=re_REPLACE_ME
FROM_EMAIL=noreply@yourdomain.com

# ── CORS (домен фронтенда) ────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-frontend.railway.app,https://strategyai.app

# ── App URL (используется в Stripe redirect URLs) ─────────────────────────────
APP_URL=https://your-frontend.railway.app

# ── Anthropic AI ─────────────────────────────────────────────────────────────
# Получи на https://console.anthropic.com/
ANTHROPIC_KEY=sk-ant-REPLACE_ME

# ── Stripe ────────────────────────────────────────────────────────────────────
# Получи на https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_REPLACE_ME

# Webhook secret — получается в Stripe Dashboard > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Price IDs — создай в Stripe Dashboard > Products
# Starter $9/мес
STRIPE_PRICE_STARTER=price_REPLACE_ME

# Pro $29/мес
STRIPE_PRICE_PRO=price_REPLACE_ME

# Team $59/мес
STRIPE_PRICE_TEAM=price_REPLACE_ME

# Enterprise $149+/мес
STRIPE_PRICE_ENTERPRISE=price_REPLACE_ME
